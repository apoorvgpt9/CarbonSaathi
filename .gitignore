# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Test & coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Type checking & linting caches
.mypy_cache/
.ruff_cache/

# Environment files & secrets (NEVER commit)
.env
.env.local
.env.*.local

# Firebase service account credentials (NEVER commit)
serviceAccountKey.json
*-firebase-adminsdk-*.json

# Logs
*.log

# OS files
.DS_Store

# Editors / IDEs
.vscode/
.idea/
*.swp

# Node (defensive — we are not using npm)
node_modules/
